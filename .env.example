# ============================================
# CONFIGURACIÓN PARA RENDER
# ============================================

# MongoDB Atlas
# Formato: mongodb+srv://USERNAME:PASSWORD@CLUSTER/DATABASE?retryWrites=true&w=majority
# Ejemplo: mongodb+srv://GProA:Adminflorida7@cluster0.9rvsd7r.mongodb.net/gproa_bimia?retryWrites=true&w=majority
# Nota: Si el password tiene caracteres especiales (@ # %), codifícalos (@=%40, #=%23, etc.)
MONGO_URL=mongodb+srv://GProA:YOUR_ENCODED_PASSWORD@cluster0.9rvsd7r.mongodb.net/gproa_bimia?retryWrites=true&w=majority

# Nombre de la base de datos
DB_NAME=gproa_bimia

# API Key de Emergent (u otro proveedor LLM)
# Obténla en: https://emergent.ai o tu provider de LLM
EMERGENT_LLM_KEY=your_api_key_here

# CORS - Para permitir el frontend
# Desarrollo: http://localhost:3000
# Producción: https://tu-servicio.onrender.com
# Todo: *
CORS_ORIGINS=*

# URL del backend (usado por el frontend en producción)
# Se configura después de hacer deploy
REACT_APP_BACKEND_URL=https://gproa-bimia.onrender.com